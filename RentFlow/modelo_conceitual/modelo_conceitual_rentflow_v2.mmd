---
config:
  layout: elk
---
flowchart TB
 subgraph FROTA["🚗 FROTA"]
    direction LR
        CATEGORIA["CATEGORIA"]
        A_cat1(["<u>id_cat</u>"])
        A_cat2(["nome"])
        A_cat3(["valor_diaria"])
        R1{"classifica"}
        VEICULO["VEICULO"]
        A_vei1(["<u>placa</u>"])
        A_vei2(["renavam"])
        A_vei3(["marca"])
        A_vei4(["modelo"])
        A_vei5(["cor"])
        A_vei6(["ano_fabricacao"])
        A_vei7(["tipo_combustivel"])
        A_vei8(["km_atual"])
        A_vei9(["nivel_combustivel"])
        A_vei10(["status"])
  end
 subgraph CLI["👤 CLIENTES"]
    direction LR
        CLIENTE["CLIENTE"]
        A_cli1(["<u>cpf</u>"])
        A_cli2(["nome"])
        A_cli3(["data_nascimento"])
        A_cli4(["email"])
        A_cli5(["inadimplente"])
        A_cli6(["cnh_numero"])
        A_cli7(["cnh_categoria"])
        A_cli8(["cnh_validade"])
        A_end(["endereco"])
        A_end1(["rua"])
        A_end2(["numero"])
        A_end3(["bairro"])
        A_end4(["cidade"])
        A_end5(["estado"])
        A_end6(["cep"])
        R2{"possui"}
        TELEFONE["TELEFONE_CLIENTE"]
        A_tel1(["<u>numero</u>"])
        A_tel2(["tipo"])
  end
 subgraph EQ["👔 EQUIPE"]
    direction TB
        FUNCIONARIO["FUNCIONARIO"]
        A_fun1(["<u>id_func</u>"])
        A_fun2(["nome"])
        A_fun3(["cpf"])
        ISA{{"d (disjunta, total)"}}
        ATENDENTE["ATENDENTE"]
        GERENTE["GERENTE"]
  end
 subgraph PROT["🛡️ PROTEÇÃO"]
    direction LR
        SEGURO["SEGURO"]
        A_seg1(["<u>id_seguro</u>"])
        A_seg2(["nome"])
        A_seg3(["descricao_cobertura"])
        A_seg4(["valor_diario"])
  end
 subgraph LOC["📋 LOCAÇÃO"]
    direction LR
        LOCACAO["LOCACAO"]
        A_loc1(["<u>id_loc</u>"])
        A_loc2(["status"])
        A_loc3(["data_reserva"])
        A_loc4(["data_retirada"])
        A_loc5(["data_devol_prevista"])
        A_loc6(["data_devol_real"])
        A_loc7(["/valor_total/"])
  end
 subgraph VIST["🔍 VISTORIAS"]
    direction LR
        VISTORIA["VISTORIA"]
        A_vis1(["<u>id_vistoria</u>"])
        A_vis2(["tipo"])
        A_vis3(["data_hora"])
        A_vis4(["km"])
        A_vis5(["nivel_combustivel"])
        A_vis6(["observacoes"])
  end
 subgraph FIN["💰 FINANCEIRO"]
    direction LR
        PAGAMENTO["PAGAMENTO"]
        A_pag1(["<u>id_pagamento</u>"])
        A_pag2(["forma_pagamento"])
        A_pag3(["valor"])
        A_pag4(["data"])
        COBRANCA_EXTRA["COBRANCA_EXTRA"]
        A_cob1(["<u>id_cobranca</u>"])
        A_cob2(["tipo"])
        A_cob3(["descricao"])
        A_cob4(["valor"])
  end
 subgraph MAN["🔧 MANUTENÇÃO"]
    direction LR
        MANUTENCAO["MANUTENCAO"]
        A_man1(["<u>id_manut</u>"])
        A_man2(["tipo"])
        A_man3(["motivo"])
        A_man4(["descricao"])
        A_man5(["data_entrada"])
        A_man6(["previsao_saida"])
        A_man7(["data_saida_real"])
        A_man8(["custo"])
  end
